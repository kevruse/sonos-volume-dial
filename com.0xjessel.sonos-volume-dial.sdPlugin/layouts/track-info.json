{
    "$schema": "https://schemas.elgato.com/streamdeck/plugins/layout.json",
    "id": "track-info",
    "items": [
        {
            "key": "albumArt",
            "type": "pixmap",
            "rect": [2, 4, 64, 70]
        },
        {
            "key": "groupName",
            "type": "text",
            "rect": [70, 4, 94, 22],
            "font": { "size": 16, "weight": 400 },
            "alignment": "left",
            "text-overflow": "ellipsis",
            "value": ""
        },
        {
            "key": "playState",
            "type": "pixmap",
            "rect": [166, 4, 22, 22]
        },
        {
            "key": "trackTitle",
            "type": "text",
            "rect": [70, 28, 128, 26],
            "font": { "size": 18, "weight": 700 },
            "alignment": "left",
            "text-overflow": "ellipsis",
            "value": ""
        },
        {
            "key": "artistName",
            "type": "text",
            "rect": [70, 56, 128, 18],
            "font": { "size": 13, "weight": 400 },
            "alignment": "left",
            "text-overflow": "ellipsis",
            "value": ""
        },
        {
            "key": "elapsed",
            "type": "text",
            "rect": [2, 76, 30, 14],
            "font": { "size": 13, "weight": 400 },
            "alignment": "right",
            "value": ""
        },
        {
            "key": "progress",
            "type": "bar",
            "rect": [34, 76, 128, 18],
            "bar_fill_c": "#FFFFFF",
            "value": 0
        },
        {
            "key": "duration",
            "type": "text",
            "rect": [164, 76, 34, 14],
            "font": { "size": 13, "weight": 400 },
            "alignment": "left",
            "value": ""
        }
    ]
}