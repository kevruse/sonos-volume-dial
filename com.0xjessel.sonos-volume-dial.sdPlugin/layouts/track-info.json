{
    "$schema": "https://schemas.elgato.com/streamdeck/plugins/layout.json",
    "id": "track-info",
    "items": [
        {
            "key": "albumArt",
            "type": "pixmap",
            "rect": [2, 2, 50, 50]
        },
        {
            "key": "groupName",
            "type": "text",
            "rect": [56, 2, 110, 22],
            "font": { "size": 16, "weight": 400 },
            "alignment": "left",
            "text-overflow": "ellipsis",
            "value": ""
        },
        {
            "key": "playState",
            "type": "pixmap",
            "rect": [168, 2, 28, 22]
        },
        {
            "key": "artistName",
            "type": "text",
            "rect": [56, 26, 140, 22],
            "font": { "size": 16, "weight": 400 },
            "alignment": "left",
            "text-overflow": "ellipsis",
            "value": ""
        },
        {
            "key": "trackTitle",
            "type": "text",
            "rect": [2, 56, 196, 18],
            "font": { "size": 18, "weight": 700 },
            "alignment": "left",
            "text-overflow": "ellipsis",
            "value": ""
        },
        {
            "key": "elapsed",
            "type": "text",
            "rect": [2, 76, 30, 22],
            "font": { "size": 13, "weight": 400 },
            "alignment": "right",
            "value": ""
        },
        {
            "key": "progress",
            "type": "bar",
            "rect": [34, 78, 128, 18],
            "bar_fill_c": "#FFFFFF",
            "value": 0
        },
        {
            "key": "duration",
            "type": "text",
            "rect": [164, 76, 34, 22],
            "font": { "size": 13, "weight": 400 },
            "alignment": "left",
            "value": ""
        }
    ]
}